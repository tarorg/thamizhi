---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/menu.astro';
---

<Layout title="Post">
  <main class="main-container">
    <!-- 1. Title Section -->
    <div class="title-section">
      <input type="text" class="title-input" placeholder="Title">
      <span class="title-icon" id="metadataButton">M</span>
    </div>
    <div class="line-1"></div>

    <!-- 2. Upload Section -->
    <div class="upload-section">
      <input type="text" class="file-name-input" placeholder="File name">
      <span class="media-text" id="mediaButton">MEDIA</span>
    </div>
    <div class="line-2"></div>

    <!-- 3. Post Section -->
    <div class="post-section">
      <div id="editor"></div>
    </div>

    <Menu />
  </main>

  <!-- Bottom Sheet -->
  <div id="bottomSheet" class="bottom-sheet hidden">
    <div class="bottom-sheet-content">
      <div class="bottom-sheet-options">
        <div class="bottom-sheet-option" data-option="Image">Image</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Video">Video</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Audio">Audio</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Pdf">PDF</div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  import Paragraph from '@editorjs/paragraph';
  import Image from '@editorjs/image';
  import Embed from '@editorjs/embed';
  import Quote from '@editorjs/quote';
  import Checklist from '@editorjs/checklist';
  import CodeTool from '@editorjs/code';
  import Table from '@editorjs/table';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize Editor.js
    const editor = new EditorJS({
      holder: 'editor',
      tools: {
        header: Header,
        list: List,
        paragraph: {
          class: Paragraph,
          inlineToolbar: true,
        },
        image: {
          class: Image,
          config: {
            endpoints: {
              byFile: 'http://localhost:8008/uploadFile',
              byUrl: 'http://localhost:8008/fetchUrl',
            }
          }
        },
        embed: Embed,
        quote: Quote,
        checklist: Checklist,
        code: CodeTool,
        table: Table,
      },
      data: {},
    });

    // Bottom Sheet functionality
    const mediaButton = document.getElementById('mediaButton');
    const bottomSheet = document.getElementById('bottomSheet');
    const sheetContent = bottomSheet?.querySelector('.bottom-sheet-content');

    function openBottomSheet() {
      bottomSheet?.classList.remove('hidden');
      setTimeout(() => {
        bottomSheet?.classList.add('visible');
      }, 10);
    }

    function closeBottomSheet() {
      bottomSheet?.classList.remove('visible');
      setTimeout(() => {
        bottomSheet?.classList.add('hidden');
      }, 300);
    }

    mediaButton?.addEventListener('click', openBottomSheet);

    bottomSheet?.addEventListener('click', (e) => {
      if (e.target === bottomSheet) {
        closeBottomSheet();
      }
    });

    const options = sheetContent?.querySelectorAll('[data-option]');
    options?.forEach(option => {
      option.addEventListener('click', () => {
        const selectedOption = option.getAttribute('data-option');
        // Remove this line to prevent changing the file name input
        // const fileNameInput = document.querySelector('.file-name-input') as HTMLInputElement;
        // if (fileNameInput && selectedOption) {
        //   fileNameInput.placeholder = `Enter ${selectedOption.toLowerCase()} name...`;
        // }
        if (mediaButton && selectedOption) {
          mediaButton.textContent = selectedOption.toUpperCase();
        }
        closeBottomSheet();
      });
    });

    // Add event listener for metadata button
    const metadataButton = document.getElementById('metadataButton');
    if (metadataButton) {
      metadataButton.addEventListener('click', () => {
        window.location.href = '/metadata';
      });
    }
  });
</script>

<style>
  :root {
    --default-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Ubuntu, "Helvetica Neue", Helvetica, Arial, "PingFang SC",
      "Hiragino Sans GB", "Microsoft Yahei UI", "Microsoft Yahei",
      "Source Han Sans CN", sans-serif;
  }

  .main-container {
    position: relative;
    width: 360px;
    height: 640px;
    margin: 0 auto;
    background: #ffffff;
    overflow: hidden;
  }

  .icons-asterisk {
    position: absolute;
    width: 36px;
    height: 36px;
    top: 14px;
    left: 303.999px;
    background: url('/asterisk.png') no-repeat center;
    background-size: cover;
    z-index: 5;
  }

  .rectangle {
    position: absolute;
    width: 27px;
    height: 25px;
    top: 19px;
    left: 269.999px;
    border: 2px solid #000000;
    z-index: 6;
    border-radius: 5px;
  }

  .flex-column-a {
    position: absolute;
    width: 79.001px;
    height: 160.094px;
    top: 21px;
    left: 28.999px;
    font-size: 0px;
    z-index: 4;
  }

  .title {
    display: block;
    position: relative;
    height: 29px;
    margin: 0;
    color: #000000;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
  }

  .media {
    display: block;
    position: relative;
    height: 29px;
    margin: 26px 0 0;
    color: #a7a0a0;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
    z-index: 1;
  }

  .line {
    position: relative;
    width: 15.498px;
    height: 24.931px;
    margin: 53px 0 0;
    background: #000000;
    z-index: 4;
  }

  .line-1, .line-2 {
    position: absolute;
    width: 360px;
    height: 1px;
    left: 0;
    background: #000000;
  }

  .line-1 {
    top: 59px;
    z-index: 3;
  }

  .line-2 {
    top: 116px;
    z-index: 2;
  }

  .title-section {
    position: relative;
    margin-top: 20px;
    padding: 0 20px;
  }

  .title-input {
    width: 100%;
    border: none;
    font-size: 24px;
    font-weight: 700;
    font-family: Inter, var(--default-font-family);
    outline: none;
  }

  .title-icon {
    position: absolute;
    right: 20px;
    top: 0;
    font-size: 24px;
    font-weight: 700;
    cursor: pointer; /* Add this to indicate it's clickable */
  }

  .upload-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    height: 57px;
  }

  .file-name-input {
    flex-grow: 1;
    border: none;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    color: #000000;
    outline: none;
    background: transparent;
  }

  .file-name-input::placeholder {
    color: #a7a0a0;
    font-weight: normal;
  }

  .media-text {
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    min-width: 24px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-text svg {
    width: 24px;
    height: 24px;
  }

  .post-section {
    position: absolute;
    top: 117px; /* Adjust this value to be just below line-2 */
    left: 0;
    right: 0;
    bottom: 0;
    padding: 20px;
    overflow-y: auto;
  }

  #editor {
    height: 100%;
  }

  /* Add these new styles for the bottom sheet */
  .bottom-sheet {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 50;
    display: flex;
    align-items: flex-end;
  }

  .bottom-sheet.hidden {
    display: none;
  }

  .bottom-sheet-content {
    background-color: white;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    padding: 24px;
    padding-bottom: 48px; /* Increased bottom padding */
    width: 100%;
    max-height: 80vh;
    transform: translateY(100%);
    transition: transform 0.3s ease-in-out;
  }

  .bottom-sheet-options {
    overflow-y: auto;
    max-height: calc(80vh - 72px); /* Adjusted for increased bottom padding */
  }

  .bottom-sheet-option {
    padding: 16px 0;
    font-size: 18px;
    cursor: pointer;
  }

  .bottom-sheet-option:hover {
    background-color: #f3f4f6;
  }

  .bottom-sheet-divider {
    height: 1px;
    background-color: #e5e7eb;
  }

  .bottom-sheet.visible .bottom-sheet-content {
    transform: translateY(0);
  }
</style>