---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/menu.astro';
---

<Layout title="Post">
  <main class="main-container">
    <!-- 1. Title Section -->
    <div class="title-section">
      <input type="text" class="title-input" placeholder="Enter title...">
      <span class="title-icon">M</span>
    </div>
    <div class="line-1"></div>

    <!-- 2. Upload Section -->
    <div class="upload-section">
      <input type="text" class="file-name-input" placeholder="Enter file name...">
      <span class="media-text">MEDIA</span>
    </div>
    <div class="line-2"></div>

    <!-- 3. Post Section -->
    <div class="post-section">
      <div id="editor"></div>
    </div>

    <Menu />
  </main>
</Layout>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';
  import List from '@editorjs/list';
  import Paragraph from '@editorjs/paragraph';
  import Image from '@editorjs/image';
  import Embed from '@editorjs/embed';
  import Quote from '@editorjs/quote';
  import Checklist from '@editorjs/checklist';
  import CodeTool from '@editorjs/code';
  import Table from '@editorjs/table';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize Editor.js
    const editor = new EditorJS({
      holder: 'editor',
      tools: {
        header: Header,
        list: List,
        paragraph: {
          class: Paragraph,
          inlineToolbar: true,
        },
        image: {
          class: Image,
          config: {
            endpoints: {
              byFile: 'http://localhost:8008/uploadFile', // Replace with your image upload endpoint
              byUrl: 'http://localhost:8008/fetchUrl',    // Replace with your URL fetch endpoint
            }
          }
        },
        embed: Embed,
        quote: Quote,
        checklist: Checklist,
        code: CodeTool,
        table: Table,
      },
      data: {}, // You can provide initial data here if needed
    });

    // Remove the event listener and related functions for the bottom sheet
  });
</script>

<style>
  :root {
    --default-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Ubuntu, "Helvetica Neue", Helvetica, Arial, "PingFang SC",
      "Hiragino Sans GB", "Microsoft Yahei UI", "Microsoft Yahei",
      "Source Han Sans CN", sans-serif;
  }

  .main-container {
    position: relative;
    width: 360px;
    height: 640px;
    margin: 0 auto;
    background: #ffffff;
    overflow: hidden;
  }

  .icons-asterisk {
    position: absolute;
    width: 36px;
    height: 36px;
    top: 14px;
    left: 303.999px;
    background: url('/asterisk.png') no-repeat center;
    background-size: cover;
    z-index: 5;
  }

  .rectangle {
    position: absolute;
    width: 27px;
    height: 25px;
    top: 19px;
    left: 269.999px;
    border: 2px solid #000000;
    z-index: 6;
    border-radius: 5px;
  }

  .flex-column-a {
    position: absolute;
    width: 79.001px;
    height: 160.094px;
    top: 21px;
    left: 28.999px;
    font-size: 0px;
    z-index: 4;
  }

  .title {
    display: block;
    position: relative;
    height: 29px;
    margin: 0;
    color: #000000;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
  }

  .media {
    display: block;
    position: relative;
    height: 29px;
    margin: 26px 0 0;
    color: #a7a0a0;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
    z-index: 1;
  }

  .line {
    position: relative;
    width: 15.498px;
    height: 24.931px;
    margin: 53px 0 0;
    background: #000000;
    z-index: 4;
  }

  .line-1, .line-2 {
    position: absolute;
    width: 360px;
    height: 1px;
    left: 0;
    background: #000000;
  }

  .line-1 {
    top: 59px;
    z-index: 3;
  }

  .line-2 {
    top: 116px;
    z-index: 2;
  }

  .title-section {
    position: relative;
    margin-top: 20px;
    padding: 0 20px;
  }

  .title-input {
    width: 100%;
    border: none;
    font-size: 24px;
    font-weight: 700;
    font-family: Inter, var(--default-font-family);
    outline: none;
  }

  .title-icon {
    position: absolute;
    right: 20px;
    top: 0;
    font-size: 24px;
    font-weight: 700;
  }

  .upload-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    height: 57px;
  }

  .file-name-input {
    flex-grow: 1;
    border: none;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    color: #000000;
    outline: none;
    background: transparent;
  }

  .file-name-input::placeholder {
    color: #a7a0a0;
    font-weight: normal;
  }

  .media-text {
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    min-width: 24px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-text svg {
    width: 24px;
    height: 24px;
  }

  .post-section {
    position: absolute;
    top: 117px; /* Adjust this value to be just below line-2 */
    left: 0;
    right: 0;
    bottom: 0;
    padding: 20px;
    overflow-y: auto;
  }

  #editor {
    height: 100%;
  }
</style>