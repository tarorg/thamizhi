---
import Layout from '../layouts/Layout.astro';
import BottomMenu from '../components/menu.astro';

const sections = [
  { title: "THAMIZHI", items: [] },
  { title: "FEED", items: [] },
  { title: "I", items: [] },
  { title: "CLUSTERS", items: [] },
];
---

<Layout title="CLUSTER">
	<main class="container">
		<div class="search-section">
			<input type="text" class="search" placeholder="Search..." />
		</div>
		<div class="line"></div>
		
		<div class="filter-section">
			<button class="filter-option active">Collections</button>
			<button class="filter-option">Clusters</button>
			<button class="filter-option">Read</button>
		</div>
		
		{sections.map((section, index) => (
			<div class="section">
				<div class="section-title">{section.title}</div>
				{section.items.map((item) => (
					<div class="section-item">{item}</div>
				))}
				{index < sections.length - 1 && <div class="line"></div>}
			</div>
		))}
		
	</main>
	<button class="fab-add" id="fabAdd">
		<svg viewBox="0 0 24 24" width="24" height="24">
			<path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
		</svg>
	</button>
	<BottomMenu />
</Layout>

<style>
	.container {
		max-width: 360px;
		margin: 0 auto;
		padding: 20px;
		box-sizing: border-box;
		font-family: 'Inter', sans-serif;
		color: #000;
		background-color: white;
	}
	.search-section {
		margin: 12px 0;
	}
	.search {
		width: 100%;
		height: 40px;
		color: #000000;
		font-size: 18px;
		font-weight: 500;
		border: none;
		outline: none;
		background: transparent;
	}
	.search::placeholder {
		color: #a7a0a0;
	}
	.line {
		width: 100%;
		height: 1px;
		margin: 14px 0;
		background: #E0E0E0;
	}
	.filter-section {
		display: flex;
		justify-content: space-between;
		margin-bottom: 30px;
	}
	.filter-option {
		background: none;
		border: none;
		font-size: 14px;
		color: #A7A1A1;
		cursor: pointer;
		padding: 8px 16px;
		border-radius: 20px;
		transition: all 0.3s ease;
	}
	.filter-option.active {
		background-color: #000000;
		color: white;
	}
	.section {
		margin-bottom: 20px;
	}
	.section-title {
		font-size: 20px;
		font-weight: 700;
		margin-bottom: 10px;
	}
	.section-item {
		font-size: 16px;
		margin-bottom: 8px;
		color: #333;
	}
	.fab-add {
		position: fixed;
		bottom: 80px;
		right: 20px;
		width: 56px;
		height: 56px;
		border-radius: 28px;
		background-color: #000000;
		color: #FFFFFF;
		border: none;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: background-color 0.3s, transform 0.2s;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
	}
	.fab-add:hover {
		background-color: #333333;
		transform: scale(1.05);
	}
	.fab-add:active {
		transform: scale(0.95);
	}
</style>

<script>
	const filterOptions = document.querySelectorAll('.filter-option');
	filterOptions.forEach(option => {
		option.addEventListener('click', () => {
			filterOptions.forEach(btn => btn.classList.remove('active'));
			option.classList.add('active');
		});
	});

	const fabAdd = document.getElementById('fabAdd');
	if (fabAdd) {
		fabAdd.addEventListener('click', () => {
			window.location.href = '/post';
		});
	}
</script>
