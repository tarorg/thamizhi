---
import Layout from '../layouts/Layout.astro';
import BottomMenu from '../components/menu.astro';
import PostComp from '../components/postcomp.astro';
---

<Layout title="CLUSTER">
	<main class="container">
		<div class="search-section">
			<input type="text" class="search" placeholder="Search..." />
		</div>
		<div class="line"></div>
		
		<div class="filter-section">
			<button class="filter-option active">Collections</button>
			<button class="filter-option">Clusters</button>
			<button class="filter-option">Posts</button>
			<button class="filter-option">Read</button>
		</div>
		
		<div class="content-section">
			<ul class="post-list" id="postList">
				<!-- Posts will be populated here by JavaScript -->
			</ul>
		</div>
		
	</main>
	<button class="fab-add" id="fabAdd">+</button>
	<BottomMenu />

	<!-- PostComp modal -->
	<div id="postCompModal" class="modal hidden">
		<div class="modal-content">
			<PostComp />
		</div>
	</div>
</Layout>

<script>
	import { getAllPosts } from '../utils/indexedDB.js';

	document.addEventListener('DOMContentLoaded', async () => {
		try {
			const posts = await getAllPosts();
			const postList = document.getElementById('postList');
			if (postList) {
				posts.forEach((post) => {
					const li = document.createElement('li');
					li.className = 'post-item';
					li.textContent = post.title;
					postList.appendChild(li);
				});
			}
		} catch (error) {
			console.error('Error fetching posts:', error);
		}

		const filterOptions = document.querySelectorAll('.filter-option');
		filterOptions.forEach(option => {
			option.addEventListener('click', () => {
				filterOptions.forEach(btn => btn.classList.remove('active'));
				option.classList.add('active');
				// Here you can add logic to filter content based on the selected filter
			});
		});

		const fabAdd = document.getElementById('fabAdd');
		const postCompModal = document.getElementById('postCompModal');
		if (fabAdd && postCompModal) {
			fabAdd.addEventListener('click', () => {
				postCompModal.classList.remove('hidden');
			});
		}

		// Close modal when clicking outside
		postCompModal?.addEventListener('click', (e) => {
			if (e.target === postCompModal) {
				postCompModal.classList.add('hidden');
			}
		});
	});
</script>

<style>
	.container {
		max-width: 360px;
		margin: 0 auto;
		padding: 20px;
		box-sizing: border-box;
		font-family: 'Inter', sans-serif;
		color: #000;
		background-color: white;
	}
	.search-section {
		margin: 12px 0;
	}
	.search {
		width: 100%;
		height: 40px;
		color: #000000;
		font-size: 18px;
		font-weight: 500;
		border: none;
		outline: none;
		background: transparent;
	}
	.search::placeholder {
		color: #a7a0a0;
	}
	.line {
		width: 100%;
		height: 1px;
		margin: 14px 0;
		background: #E0E0E0;
	}
	.filter-section {
		display: flex;
		justify-content: space-between;
		margin-bottom: 30px;
		flex-wrap: wrap;
	}
	.filter-option {
		background: none;
		border: none;
		font-size: 14px;
		color: #A7A1A1;
		cursor: pointer;
		padding: 8px 16px;
		border-radius: 20px;
		transition: all 0.3s ease;
		margin-bottom: 10px;
	}
	.filter-option.active {
		background-color: #000000;
		color: white;
	}
	.content-section {
		max-height: calc(100vh - 200px);
		overflow-y: auto;
	}
	.fab-add {
		position: fixed;
		bottom: 80px;
		right: 20px;
		width: 56px;
		height: 56px;
		border-radius: 28px;
		background-color: #000000;
		color: #FFFFFF;
		border: none;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: background-color 0.3s, transform 0.2s;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
		font-size: 24px;
	}
	.fab-add:hover {
		background-color: #333333;
		transform: scale(1.05);
	}
	.fab-add:active {
		transform: scale(0.95);
	}
	.post-list {
		list-style-type: none;
		padding: 0;
		margin: 0;
	}
	.post-item {
		padding: 15px 0;
		border-bottom: 1px solid #e0e0e0;
		font-size: 16px;
		color: #333;
	}
	.post-item:last-child {
		border-bottom: none;
	}
	
	.modal {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0, 0, 0, 0.5);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
	}

	.modal-content {
		width: 100%;
		height: 100%;
		overflow-y: auto;
		background-color: white;
	}

	.modal.hidden {
		display: none;
	}

	@media (min-width: 768px) {
		.modal-content {
			width: 80%;
			height: 90%;
			max-width: 1200px;
			border-radius: 8px;
		}
	}
</style>
