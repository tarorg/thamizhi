---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/menu.astro';
---

<Layout title="Post">
  <main class="main-container">
    <!-- Collection Section -->
    <div class="text-section">
      <input type="text" class="text-input" placeholder="Collection">
    </div>
    <div class="line"></div>

    <!-- Cluster Section -->
    <div class="text-section">
      <input type="text" class="text-input" placeholder="Cluster">
    </div>
    <div class="line"></div>

    <!-- Tags Section -->
    <div class="text-section">
      <input type="text" class="text-input" placeholder="Tags">
    </div>
    <div class="line"></div>

    <!-- 2. Upload Section -->
    <div class="upload-section">
      <input type="text" class="file-name-input" placeholder="File name">
      <span class="media-text" id="mediaButton">MEDIA</span>
    </div>
    <div class="line"></div>

    <!-- Notes Section -->
    <div class="notes-section">
      <div id="editor"></div>
    </div>

    <!-- Publish Button -->
    <div class="publish-button-container">
      <button class="publish-button">Publish</button>
    </div>

    <Menu />
  </main>

  <!-- Bottom Sheet -->
  <div id="bottomSheet" class="bottom-sheet hidden">
    <div class="bottom-sheet-content">
      <div class="bottom-sheet-options">
        <div class="bottom-sheet-option" data-option="Image">Image</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Video">Video</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Audio">Audio</div>
        <div class="bottom-sheet-divider"></div>
        <div class="bottom-sheet-option" data-option="Pdf">PDF</div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize Editor.js
    const editor = new EditorJS({
      holder: 'editor',
      tools: {
        header: {
          class: Header,
          inlineToolbar: true,
          config: {
            levels: [2, 3, 4],
            defaultLevel: 3
          }
        },
        paragraph: {
          inlineToolbar: true,
        },
      },
      data: {
        blocks: [
          {
            type: "header",
            data: {
              text: "Notes",
              level: 2
            }
          },
          {
            type: "paragraph",
            data: {
              text: "Start typing your notes here..."
            }
          }
        ]
      },
    });

    // Bottom Sheet functionality
    const mediaButton = document.getElementById('mediaButton');
    const bottomSheet = document.getElementById('bottomSheet');
    const sheetContent = bottomSheet?.querySelector('.bottom-sheet-content');

    function openBottomSheet() {
      bottomSheet?.classList.remove('hidden');
      setTimeout(() => {
        bottomSheet?.classList.add('visible');
      }, 10);
    }

    function closeBottomSheet() {
      bottomSheet?.classList.remove('visible');
      setTimeout(() => {
        bottomSheet?.classList.add('hidden');
      }, 300);
    }

    mediaButton?.addEventListener('click', openBottomSheet);

    bottomSheet?.addEventListener('click', (e) => {
      if (e.target === bottomSheet) {
        closeBottomSheet();
      }
    });

    const options = sheetContent?.querySelectorAll('[data-option]');
    options?.forEach(option => {
      option.addEventListener('click', () => {
        const selectedOption = option.getAttribute('data-option');
        // Remove this line to prevent changing the file name input
        // const fileNameInput = document.querySelector('.file-name-input') as HTMLInputElement;
        // if (fileNameInput && selectedOption) {
        //   fileNameInput.placeholder = `Enter ${selectedOption.toLowerCase()} name...`;
        // }
        if (mediaButton && selectedOption) {
          mediaButton.textContent = selectedOption.toUpperCase();
        }
        closeBottomSheet();
      });
    });

    // Add event listener for publish button
    const publishButton = document.querySelector('.publish-button');
    if (publishButton) {
      publishButton.addEventListener('click', () => {
        // Add your publish logic here
        console.log('Publish button clicked');
      });
    }
  });
</script>

<style>
  :root {
    --default-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Ubuntu, "Helvetica Neue", Helvetica, Arial, "PingFang SC",
      "Hiragino Sans GB", "Microsoft Yahei UI", "Microsoft Yahei",
      "Source Han Sans CN", sans-serif;
  }

  .main-container {
    position: relative;
    width: 360px;
    height: 640px;
    margin: 0 auto;
    background: #ffffff;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .icons-asterisk {
    position: absolute;
    width: 36px;
    height: 36px;
    top: 14px;
    left: 303.999px;
    background: url('/asterisk.png') no-repeat center;
    background-size: cover;
    z-index: 5;
  }

  .rectangle {
    position: absolute;
    width: 27px;
    height: 25px;
    top: 19px;
    left: 269.999px;
    border: 2px solid #000000;
    z-index: 6;
    border-radius: 5px;
  }

  .flex-column-a {
    position: absolute;
    width: 79.001px;
    height: 160.094px;
    top: 21px;
    left: 28.999px;
    font-size: 0px;
    z-index: 4;
  }

  .title {
    display: block;
    position: relative;
    height: 29px;
    margin: 0;
    color: #000000;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
  }

  .media {
    display: block;
    position: relative;
    height: 29px;
    margin: 26px 0 0;
    color: #a7a0a0;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
    z-index: 1;
  }

  .line {
    position: relative;
    width: 15.498px;
    height: 24.931px;
    margin: 53px 0 0;
    background: #000000;
    z-index: 4;
  }

  .line-1, .line-2 {
    position: absolute;
    width: 360px;
    height: 1px;
    left: 0;
    background: #000000;
  }

  .line-1 {
    top: 59px;
    z-index: 3;
  }

  .line-2 {
    top: 116px;
    z-index: 2;
  }

  .title-section {
    position: relative;
    margin-top: 20px;
    padding: 0 20px;
  }

  .title-input {
    width: 100%;
    border: none;
    font-size: 24px;
    font-weight: 700;
    font-family: Inter, var(--default-font-family);
    outline: none;
  }

  .title-icon {
    position: absolute;
    right: 20px;
    top: 0;
    font-size: 24px;
    font-weight: 700;
  }

  .upload-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    height: 57px;
  }

  .file-name-input {
    flex-grow: 1;
    border: none;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    color: #000000;
    outline: none;
    background: transparent;
  }

  .file-name-input::placeholder {
    color: #a7a0a0;
    font-weight: normal;
  }

  .media-text {
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    min-width: 24px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-text svg {
    width: 24px;
    height: 24px;
  }

  .notes-section {
    flex-grow: 1;
    overflow-y: auto;
    padding: 20px;
  }

  #editor {
    height: 100%;
  }

  /* Add these new styles for the bottom sheet */
  .bottom-sheet {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 50;
    display: flex;
    align-items: flex-end;
  }

  .bottom-sheet.hidden {
    display: none;
  }

  .bottom-sheet-content {
    background-color: white;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    padding: 24px;
    padding-bottom: 48px; /* Increased bottom padding */
    width: 100%;
    max-height: 80vh;
    transform: translateY(100%);
    transition: transform 0.3s ease-in-out;
  }

  .bottom-sheet-options {
    overflow-y: auto;
    max-height: calc(80vh - 72px); /* Adjusted for increased bottom padding */
  }

  .bottom-sheet-option {
    padding: 16px 0;
    font-size: 18px;
    cursor: pointer;
  }

  .bottom-sheet-option:hover {
    background-color: #f3f4f6;
  }

  .bottom-sheet-divider {
    height: 1px;
    background-color: #e5e7eb;
  }

  .bottom-sheet.visible .bottom-sheet-content {
    transform: translateY(0);
  }

  .text-section {
    position: relative;
    padding: 10px 20px;
  }

  .text-input {
    width: 100%;
    border: none;
    font-size: 18px;
    font-weight: 700;
    font-family: Inter, var(--default-font-family);
    outline: none;
  }

  .line {
    width: 100%;
    height: 1px;
    background: #000000;
    margin: 0;
  }

  .upload-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
  }

  /* Remove the .text-icon style as it's no longer needed */

  .publish-button-container {
    padding: 16px;
    background-color: #ffffff;
  }

  .publish-button {
    width: 100%;
    padding: 16px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.1s ease;
  }

  .publish-button:hover {
    background-color: #333333;
  }

  .publish-button:active {
    transform: scale(0.98);
  }
</style>