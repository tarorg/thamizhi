---
import Layout from '../layouts/Layout.astro';
import Menu from '../components/menu.astro';
---

<Layout title="Metadata">
  <main class="main-container">
    <span class="cluster">CLUSTER</span>
    <span class="thumbnail">THUMBNAIL</span>
    <span class="collection">COLLECTION</span>
    <span class="tags">TAGS</span>
    <div class="line"></div>
    <div class="line-1"></div>
    <div class="line-2"></div>
    <div class="line-3"></div>
    <Menu />
  </main>
</Layout>

<style>
  :root {
    --default-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Ubuntu, "Helvetica Neue", Helvetica, Arial, "PingFang SC",
      "Hiragino Sans GB", "Microsoft Yahei UI", "Microsoft Yahei",
      "Source Han Sans CN", sans-serif;
  }

  .main-container {
    position: relative;
    width: 360px;
    height: 640px;
    margin: 0 auto;
    font-size: 0px;
    background: #ffffff;
    overflow: hidden;
  }

  .cluster,
  .thumbnail,
  .collection,
  .tags {
    display: block;
    position: relative;
    height: 29px;
    margin-left: 29px;
    font-family: Inter, var(--default-font-family);
    font-size: 24px;
    font-weight: 700;
    line-height: 29px;
    text-align: left;
    white-space: nowrap;
  }

  .cluster {
    margin-top: 21px;
    color: #000000;
  }

  .thumbnail {
    margin-top: 26px;
    color: #a7a0a0;
    z-index: 1;
  }

  .collection {
    margin-top: 28px;
    color: #a7a0a0;
    z-index: 3;
  }

  .tags {
    margin-top: 28px;
    color: #a7a0a0;
    z-index: 4;
  }

  .line,
  .line-1,
  .line-2,
  .line-3 {
    position: absolute;
    width: 360px;
    height: 1px;
    left: 0;
    background: #000000;
  }

  .line {
    top: 59px;
    z-index: 7;
  }

  .line-1 {
    top: 116px;
    z-index: 2;
  }

  .line-2 {
    top: 173px;
    z-index: 5;
  }

  .line-3 {
    top: 230px;
    z-index: 6;
  }
</style>
