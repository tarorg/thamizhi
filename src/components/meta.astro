---
import EditorJS from '@editorjs/editorjs';
import Header from '@editorjs/header';

interface Props {
  title?: string;
}

const { title = "Metadata" } = Astro.props;
---

<div class="metadata-container">
  <!-- Collection Section -->
  <div class="text-section">
    <input type="text" class="text-input" placeholder="Collection">
  </div>
  <div class="line"></div>

  <!-- Cluster Section -->
  <div class="text-section">
    <input type="text" class="text-input" placeholder="Cluster">
  </div>
  <div class="line"></div>

  <!-- Tags Section -->
  <div class="text-section">
    <input type="text" class="text-input" placeholder="Tags">
  </div>
  <div class="line"></div>

  <!-- Upload Section -->
  <div class="upload-section">
    <input type="text" class="file-name-input" placeholder="File name">
    <span class="media-text" id="mediaButton">MEDIA</span>
  </div>
  <div class="line"></div>

  <!-- Notes Section -->
  <div class="notes-section">
    <div id="editorjs"></div>
  </div>

  <!-- Publish Button -->
  <div class="publish-button-container">
    <button class="publish-button">Publish</button>
  </div>
</div>

<!-- Bottom Sheet -->
<div id="bottomSheet" class="bottom-sheet hidden">
  <div class="bottom-sheet-content">
    <div class="bottom-sheet-options">
      <div class="bottom-sheet-option" data-option="Image">Image</div>
      <div class="bottom-sheet-divider"></div>
      <div class="bottom-sheet-option" data-option="Video">Video</div>
      <div class="bottom-sheet-divider"></div>
      <div class="bottom-sheet-option" data-option="Audio">Audio</div>
      <div class="bottom-sheet-divider"></div>
      <div class="bottom-sheet-option" data-option="Pdf">PDF</div>
    </div>
  </div>
</div>

<script>
  import EditorJS from '@editorjs/editorjs';
  import Header from '@editorjs/header';

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize Editor.js
    const editor = new EditorJS({
      holder: 'editorjs',
      tools: {
        header: {
          class: Header,
          inlineToolbar: true,
          config: {
            levels: [2, 3, 4],
            defaultLevel: 3
          }
        },
        paragraph: {
          inlineToolbar: true,
        },
      },
      data: {
        blocks: [
          {
            type: "header",
            data: {
              text: "Notes",
              level: 2
            }
          },
          {
            type: "paragraph",
            data: {
              text: "Start typing your notes here..."
            }
          }
        ]
      },
    });

    // Bottom Sheet functionality
    const mediaButton = document.getElementById('mediaButton');
    const bottomSheet = document.getElementById('bottomSheet');
    const sheetContent = bottomSheet?.querySelector('.bottom-sheet-content');

    function openBottomSheet() {
      bottomSheet?.classList.remove('hidden');
      setTimeout(() => {
        bottomSheet?.classList.add('visible');
      }, 10);
    }

    function closeBottomSheet() {
      bottomSheet?.classList.remove('visible');
      setTimeout(() => {
        bottomSheet?.classList.add('hidden');
      }, 300);
    }

    mediaButton?.addEventListener('click', openBottomSheet);

    bottomSheet?.addEventListener('click', (e) => {
      if (e.target === bottomSheet) {
        closeBottomSheet();
      }
    });

    const options = sheetContent?.querySelectorAll('[data-option]');
    options?.forEach(option => {
      option.addEventListener('click', () => {
        const selectedOption = option.getAttribute('data-option');
        if (mediaButton && selectedOption) {
          mediaButton.textContent = selectedOption.toUpperCase();
        }
        closeBottomSheet();
      });
    });

    // Add event listener for publish button
    const publishButton = document.querySelector('.publish-button');
    if (publishButton) {
      publishButton.addEventListener('click', () => {
        // Add your publish logic here
        console.log('Publish button clicked');
      });
    }
  });
</script>

<style>
  /* All the styles from metadata.astro */
  :root {
    --default-font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      Ubuntu, "Helvetica Neue", Helvetica, Arial, "PingFang SC",
      "Hiragino Sans GB", "Microsoft Yahei UI", "Microsoft Yahei",
      "Source Han Sans CN", sans-serif;
  }

  .metadata-container {
    width: 100%;
    height: 100%;
    background: #ffffff;
    display: flex;
    flex-direction: column;
  }

  .text-section {
    position: relative;
    padding: 10px 20px;
  }

  .text-input {
    width: 100%;
    border: none;
    font-size: 18px;
    font-weight: 700;
    font-family: Inter, var(--default-font-family);
    outline: none;
  }

  .line {
    width: 100%;
    height: 1px;
    background: #000000;
    margin: 0;
  }

  .upload-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    height: 57px;
  }

  .file-name-input {
    flex-grow: 1;
    border: none;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    color: #000000;
    outline: none;
    background: transparent;
  }

  .file-name-input::placeholder {
    color: #a7a0a0;
    font-weight: normal;
  }

  .media-text {
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 700;
    cursor: pointer;
    min-width: 24px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .notes-section {
    flex-grow: 1;
    overflow-y: auto;
    padding: 20px;
    min-height: 200px; /* Ensure a minimum height */
  }

  #editorjs {
    height: 100%;
    min-height: 200px;
  }

  .bottom-sheet {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 50;
    display: flex;
    align-items: flex-end;
  }

  .bottom-sheet.hidden {
    display: none;
  }

  .bottom-sheet-content {
    background-color: white;
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    padding: 24px;
    padding-bottom: 48px;
    width: 100%;
    max-height: 80vh;
    transform: translateY(100%);
    transition: transform 0.3s ease-in-out;
  }

  .bottom-sheet-options {
    overflow-y: auto;
    max-height: calc(80vh - 72px);
  }

  .bottom-sheet-option {
    padding: 16px 0;
    font-size: 18px;
    cursor: pointer;
  }

  .bottom-sheet-option:hover {
    background-color: #f3f4f6;
  }

  .bottom-sheet-divider {
    height: 1px;
    background-color: #e5e7eb;
  }

  .bottom-sheet.visible .bottom-sheet-content {
    transform: translateY(0);
  }

  .publish-button-container {
    padding: 16px;
    background-color: #ffffff;
  }

  .publish-button {
    width: 100%;
    padding: 16px;
    background-color: #000000;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-family: Inter, var(--default-font-family);
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.1s ease;
  }

  .publish-button:hover {
    background-color: #333333;
  }

  .publish-button:active {
    transform: scale(0.98);
  }
</style>